# Twitch Drops Miner headless environment
# Copy to /etc/default/twitchdropsminer or ~/.config/twitchdropsminer.env for your own use.

# Comma-separated Twitch game names
TDM_PRIORITY=Rust,VALORANT
TDM_EXCLUDE=

# One of: priority-only | ending-soonest | low-availability-first
TDM_PRIORITY_MODE=priority-only

# 1..6
TDM_CONNECTION_QUALITY=3

# 1 enables --available-drops-check
TDM_AVAILABLE_DROPS_CHECK=0

# Set to 1 if you explicitly want to pass --no-available-drops-check
TDM_FORCE_DISABLE_DROPS_CHECK=1

# Optional: -v, -vv, -vvv, -vvvv
TDM_VERBOSE=-vv

# Any additional raw args appended at the end
TDM_EXTRA_ARGS=
